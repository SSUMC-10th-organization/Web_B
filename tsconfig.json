{
	"compilerOptions": {
		"jsx": "react-jsx",         
    "moduleResolution": "bundler", 
    "allowImportingTsExtensions": true, 
		"target": "ESNext",
		"module": "ESNext",
		//"moduleResolution": "node",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowJs": true,
		"noEmit": true,
		"isolatedModules": true
	},
	"include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
	"exclude": ["node_modules", "dist"]
}

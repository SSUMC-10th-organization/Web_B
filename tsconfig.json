{
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowJs": true,
		"noEmit": true,
		"isolatedModules": true,
		"baseUrl": ".",
			"paths": {
			"*": [
				"node_modules/*",
				"**/node_modules/*" 
			]
			}
	},
	"include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
	"exclude": ["node_modules"]
}